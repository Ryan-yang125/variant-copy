{
  "manifest_version": 3,
  "name": "Variant Copy",
  "description": "Copy HTML source from Variant community cards.",
  "version": "0.1.0",
  "permissions": ["activeTab", "clipboardWrite"],
  "host_permissions": ["https://variant.com/design/*.html"],
  "action": {
    "default_title": "Variant Copy",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://variant.com/community*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
